# Supabase (Auth: anon key used in browser and middleware)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Supabase (server-side DB/storage only)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Vercel Blob
BLOB_READ_WRITE_TOKEN=<vercel-blob-read-write-token>

# Art approvals (client OTP + review session HMAC; min 16 chars each)
ART_APPROVAL_OTP_SECRET=<random-secret>
ART_APPROVAL_REVIEW_SESSION_SECRET=<random-secret>
# OTP codes are written to server logs (Vercel/host logs) for operators to share with clients.
