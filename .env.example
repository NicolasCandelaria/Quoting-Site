# Supabase (Auth: anon key used in browser and middleware)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Supabase (server-side DB/storage only)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Vercel Blob
BLOB_READ_WRITE_TOKEN=<vercel-blob-read-write-token>

# Art approvals (client OTP + review session HMAC; min 16 chars each)
ART_APPROVAL_OTP_SECRET=<random-secret>
ART_APPROVAL_REVIEW_SESSION_SECRET=<random-secret>
# Client sign-in: optional Resend sends magic link + code (like internal Supabase magic links).
# Without RESEND_API_KEY, link and code are logged for operators to share.
# Resend testing: until you verify a domain at resend.com/domains, Resend may only allow sending
# to your own account email; use RESEND_FROM_EMAIL on a verified domain for real client addresses.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
